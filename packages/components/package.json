		"url": "git+https://github.com/issue9/cmfx",
		"directory": "packages/components"
	},
	"keywords": [
		"cmfx",
		"components",
		"ui"
	],
	"license": "MIT",
	"files": [
		"lib/",
		"README.md",
		"LICENSE"
	],
	"types": "./lib/index.d.ts",
	"module": "./lib/index.js",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		},
		"./style.css": "./lib/style.css",
		"./tailwind.css": "./lib/tailwind.css",
