{
	"extends": "../../build/tsconfig.base.json",
	"compilerOptions": {
		"types": ["vite/client", "unplugin-icons/types/solid"],
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"paths": {
			"@dashboard/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.mts", "src/**/*.mjs", "src/**/*.js", "src/**/*.tsx"],
	"exclude": ["dist"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
