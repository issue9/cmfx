[
	{
		"kind": "interface",
		"name": "Tab.RootProps",
		"properties": [
			{
				"name": "items",
				"summary": "所有的 tab 项\n\n",
				"type": "Item_2[]",
				"reactive": true
			},
			{
				"name": "layout",
				"summary": "布局\n\n",
				"type": "\"horizontal\" | \"vertical\" | undefined",
				"def": "'horizontal'\n\n"
			},
			{
				"name": "value",
				"summary": "默认选中的值，如果为空，则选中第一个项。\n\n",
				"type": "string | undefined",
				"reactive": true
			},
			{
				"name": "panelClass",
				"summary": "应用在标签面板上的样式\n\n",
				"type": "string | undefined",
				"reactive": true
			},
			{
				"name": "onChange",
				"summary": "标签切换时的回调函数\n\n",
				"type": "ChangeFunc<string> | undefined"
			},
			{
				"name": "palette",
				"summary": "指定当前组件采用的色盘\n\n",
				"remarks": "如果指定了此值，那么在组件内部的 CSS 引用的诸如\n`--palette-bg`\n等 CSS 变量都将使用此色盘对应的颜色。\n如果是 undefined，则表示从父元素继承。\n\n",
				"type": "\"primary\" | \"secondary\" | \"tertiary\" | \"error\" | \"surface\" | undefined",
				"reactive": true
			},
			{
				"name": "class",
				"summary": "为组件的根元素指定 CSS 类名\n\n",
				"remarks": "为当前组件的根元素指定 CSS 类名。该值始终是最后添加到元素的 class 属性上的，\n以保证此类能启作用，当然也有可能会修改组件的定义的一些 CSS 样式。\n\n",
				"type": "string | undefined",
				"reactive": true
			},
			{
				"name": "style",
				"summary": "组件根元素的样式\n\n",
				"remarks": "相对于\n，一些简短的样式设置，直接使用此属性更方便，\n还有一些自定义的样式变量也可以使用此属性设置。\n\n",
				"type": "string | JSX.CSSProperties | undefined",
				"reactive": true
			},
			{
				"name": "children",
				"type": "JSX.Element"
			},
			{
				"name": "ref",
				"summary": "对当前组件的一些次要操作可能会通过此方法给出\n\n",
				"type": "((m: REF) => void) | undefined"
			}
		],
		"pkg": "@cmfx/components"
	},
	{
		"kind": "interface",
		"name": "Tab.RootRef",
		"methods": [
			{
				"name": "switch",
				"summary": "切换到指定的标签\n\n",
				"type": "switch(id: Item_2['id']): void",
				"params": [
					{
						"name": "id",
						"type": "string"
					}
				],
				"return": {
					"type": "void"
				}
			},
			{
				"name": "scroll",
				"summary": "滚动标签列表\n\n",
				"type": "scroll(delta: number): void",
				"params": [
					{
						"name": "delta",
						"summary": "滚动的距离，正数向右滚动，负数向左滚动。\n\n",
						"type": "number"
					}
				],
				"return": {
					"type": "void"
				}
			},
			{
				"name": "root",
				"summary": "返回组件的根元素\n\n",
				"type": "root(): T",
				"return": {
					"type": "T"
				}
			}
		],
		"pkg": "@cmfx/components"
	},
	{
		"kind": "interface",
		"name": "Tab.Item",
		"properties": [
			{
				"name": "id",
				"summary": "该 Tab 的唯一 ID\n\n",
				"type": "string"
			},
			{
				"name": "label",
				"summary": "Tab 标签上的内容\n\n",
				"type": "JSX.Element"
			},
			{
				"name": "disabled",
				"summary": "该标签处于禁用状态\n\n",
				"type": "boolean | undefined"
			}
		],
		"pkg": "@cmfx/components"
	}
]