						"type": "boolean | undefined",
						"reactive": true
					},
					{
						"name": "rounded",
						"summary": "表单组件的 rounded 属性的默认值\n\n",
						"type": "boolean | undefined",
						"reactive": true
					},
					{
						"name": "tabindex",
						"summary": "tabindex 属性\n\n",
						"type": "number | undefined",
						"def": "0\n\n",
						"reactive": true
					},
					{
						"name": "ref",
						"summary": "对当前组件的一些次要操作可能会通过此方法给出\n\n",
						"type": "((m: REF) => void) | undefined"
					}
				]
			}
		],
		"discriminant": "multiple",
		"pkg": "@cmfx/components"
	},
	{
		"kind": "interface",
		"methods": [
			{
				"name": "root",
				"summary": "返回组件的根元素\n\n",
				"type": "root(): T",
				"return": {
					"type": "T"
				}
			}
		],
		"name": "Choice.Ref",
		"pkg": "@cmfx/components"
	},
	{
		"name": "Choice.Option",
		"summary": "单个选择项的类型\n\n",
		"remarks": "直接采用了与\n`MenuItem`\n相同的类型，但是对为 type 为 a 的项是忽略处理的。\n\n",
		"kind": "union",
		"types": [
			{
				"kind": "interface",
				"name": "MenuItemDivider",
				"properties": [
					{
						"name": "type",
						"type": "\"divider\""
					}
				]
			},
			{
				"kind": "interface",
				"name": "MenuItemGroup",
				"typeParams": [
					{
						"name": "T",
						"type": "AvailableEnumType",
						"init": "string"
					}
				],
				"properties": [
					{
						"name": "type",
						"type": "\"group\""
					},
					{
						"name": "label",
						"type": "JSX.Element"
					},
					{
						"name": "items",
						"summary": "分组的子项\n\n",
						"type": "MenuItem<T>[]"
					}
				]
			},
			{
				"kind": "interface",
				"name": "MenuItemItem",
				"typeParams": [
					{
						"name": "T",
						"type": "AvailableEnumType",
						"init": "string"
					}
				],
				"properties": [
					{
						"name": "type",
						"summary": "表示普通的菜单项，如果为 a 表示这是一个链接。\n\n",
						"type": "\"a\" | \"item\""
					},
					{
						"name": "value",
						"summary": "表示当前项的唯一值\n\n",
						"remarks": "该值为空时，\n`items`\n不能为空，\n如果\n`type`\n为 a 时，当前值表示链接的地址。\n\n",
						"type": "T | undefined"
					},
					{
						"name": "label",
						"summary": "菜单项的内容\n\n",
						"type": "JSX.Element"
					},
					{
						"name": "prefix",
						"summary": "菜单项前置的内容\n\n",
						"type": "JSX.Element"
					},
					{
						"name": "suffix",
						"summary": "菜单项尾部的内容\n\n",
						"remarks": "当\n`items`\n不为空时，该值无效。\n\n",
						"type": "JSX.Element"
					},
					{
						"name": "disabled",
						"summary": "是否禁用该项\n\n",
						"type": "boolean | undefined"
					},
					{
						"name": "hotkey",
						"summary": "快捷键\n\n",
						"type": "Hotkey | undefined"
					}
				]
			},
			{
				"kind": "interface",
				"name": "MenuItemItems",
				"typeParams": [
					{
						"name": "T",
						"type": "AvailableEnumType",
						"init": "string"
					}
				],
				"properties": [
					{
						"name": "type",
						"type": "\"items\""
					},
					{
						"name": "items",
						"summary": "子项\n\n",
						"remarks": "该值为空时，\n`value`\n不能为空。\n\n",
						"type": "MenuItem<T>[] | undefined"
					},
					{
						"name": "label",
						"summary": "菜单项的内容\n\n",
						"type": "JSX.Element"
					},
					{
						"name": "prefix",
						"summary": "菜单项前置的内容\n\n",
						"type": "JSX.Element"
					},
					{
						"name": "suffix",
						"summary": "菜单项尾部的内容\n\n",
						"remarks": "当\n`items`\n不为空时，该值无效。\n\n",
						"type": "JSX.Element"
					},
					{
						"name": "disabled",
						"summary": "是否禁用该项\n\n",
						"type": "boolean | undefined"
					}
				]
			}
		],
		"discriminant": "type",
		"pkg": "@cmfx/components"
