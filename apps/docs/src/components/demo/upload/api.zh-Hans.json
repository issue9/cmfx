[
	{
		"kind": "interface",
		"name": "Upload.Props",
		"properties": [
			{
				"name": "fieldName",
				"summary": "上传文件在表单中的名称\n\n",
				"type": "string"
			},
			{
				"name": "multiple",
				"summary": "是否多选\n\n",
				"type": "boolean | undefined"
			},
			{
				"name": "accept",
				"summary": "支持的文件列表，同 https://developer.mozilla.org/zh-CN/docs/Web/HTML/Attributes/accept，但改为数组类型。\n\n",
				"type": "string[] | undefined"
			},
			{
				"name": "ref",
				"type": "(el: UploadRef) => void"
			},
			{
				"name": "dropzone",
				"summary": "指定一个接受拖拖拽文件的区域\n\n",
				"type": "HTMLElement | undefined"
			},
			{
				"name": "upload",
				"summary": "执行上传操作\n\n",
				"type": "(obj: FormData) => Promise<Array<string> | undefined>"
			},
			{
				"name": "tabindex",
				"summary": "tabindex 属性\n\n",
				"type": "number | undefined",
				"def": "0\n\n",
				"reactive": true
			},
			{
				"name": "disabled",
				"summary": "禁用组件\n\n",
				"type": "boolean | undefined",
				"reactive": true
			},
			{
				"name": "readonly",
				"summary": "只读属性\n\n",
				"type": "boolean | undefined",
				"reactive": true
			},
			{
				"name": "value",
				"summary": "传递给组件的值\n\n",
				"remarks": "在 Form 之内，此属性不是可响应的，其值由 Form.Field 的 name 指定。\n\n",
				"type": "T | undefined",
				"reactive": true
			},
			{
				"name": "onChange",
				"summary": "`value`\n变化时的回调方法\n\n",
				"type": "ChangeFunc<T | undefined> | undefined",
				"readonly": true
			},
			{
				"name": "palette",
				"summary": "指定当前组件采用的色盘\n\n",
				"remarks": "如果指定了此值，那么在组件内部的 CSS 引用的诸如\n`--palette-bg`\n等 CSS 变量都将使用此色盘对应的颜色。\n如果是 undefined，则表示从父元素继承。\n\n",
				"type": "\"primary\" | \"secondary\" | \"tertiary\" | \"error\" | \"surface\" | undefined",
				"reactive": true
			},
			{
				"name": "class",
				"summary": "为组件的根元素指定 CSS 类名\n\n",
				"remarks": "为当前组件的根元素指定 CSS 类名。该值始终是最后添加到元素的 class 属性上的，\n以保证此类能启作用，当然也有可能会修改组件的定义的一些 CSS 样式。\n\n",
				"type": "string | undefined",
				"reactive": true
			},
			{
				"name": "style",
				"summary": "组件根元素的样式\n\n",
				"remarks": "相对于\n，一些简短的样式设置，直接使用此属性更方便，\n还有一些自定义的样式变量也可以使用此属性设置。\n\n",
				"type": "string | JSX.CSSProperties | undefined",
				"reactive": true
			}
		],
		"pkg": "@cmfx/components"
	},
	{
		"kind": "interface",
		"name": "Upload.Ref",
		"summary": "上传组件的外放接口\n\n",
		"methods": [
			{
				"name": "pick",
				"summary": "显示文件选取对话框，如果有选择文件的话，还自动添加至\n`files`\n中。\n\n",
				"type": "pick(): void",
				"return": {
					"type": "void"
				}
			},
			{
				"name": "files",
				"summary": "返回所有未上传的文件\n\n",
				"type": "files(): Array<File>",
				"return": {
					"type": "File[]"
				}
			},
			{
				"name": "delete",
				"summary": "删除\n`files`\n中的第 index 对象\n\n",
				"type": "delete(index: number): void",
				"params": [
					{
						"name": "index",
						"type": "number"
					}
				],
				"return": {
					"type": "void"
				}
			},
			{
				"name": "clear",
				"summary": "清除所有未上传的内容\n\n",
				"type": "clear(): void",
				"return": {
					"type": "void"
				}
			},
			{
				"name": "upload",
				"summary": "上传\n`files`\n中的文件\n\n",
				"type": "upload(): Promise<Array<string> | undefined>",
				"return": {
					"type": "Promise<string[] | undefined>"
				}
			},
			{
				"name": "root",
				"summary": "返回组件的根元素\n\n",
				"type": "root(): T",
				"return": {
					"type": "T"
				}
			}
		],
		"pkg": "@cmfx/components"
	},
