{
	"extends": "../../build/tsconfig.base.json",
	"compilerOptions": {
		"types": ["vite/client", "@testing-library/jest-dom", "unplugin-icons/types/solid"],
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"paths": {
			"@docs/*": ["./src/*"]
		},
		"outDir": "../../docs"
	},
	"include": [
		"src/**/api.*.json",
		"src/**/*.ts",
		"src/**/*.mts",
		"src/**/*.mjs",
		"src/**/*.js",
		"src/**/*.tsx",
		"../../pakcages/**/*.tsx",
		"../../pakcages/**/*.ts",
		"./package.json"
	],
	"references": [
		{
			"path": "./tsconfig.node.json"
		}
	]
}
