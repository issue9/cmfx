{
	"extends": "../../build/tsconfig.base.json",
	"compilerOptions": {
		"types": ["vite/client", "@testing-library/jest-dom", "unplugin-icons/types/solid"],
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"paths": {
			"@docs/*": ["./src/*"]
		},
		"outDir": "./dist"
	},
	"include": ["src/**/*.ts", "src/**/*.mts", "src/**/*.mjs", "src/**/*.js", "src/**/*.tsx", "./package.json"],
	"exclude": ["dist"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
